import { describe, it, expect, vi } from 'vitest'
import type { IAgentTaskRepository } from '../../data/sprint-task-repository'
import type { SprintTask } from '../../../shared/types'

vi.mock('../diff-snapshot', () => ({
  captureDiffSnapshot: vi.fn().mockResolvedValue(null)
}))

// Import after mocks are registered
const { transitionToReview } = await import('../review-transition')

function makeMinimalTask(overrides: Partial<SprintTask> = {}): SprintTask {
  return {
    id: 'task-1',
    title: 'Test task',
    status: 'running',
    priority: 0,
    retry_count: 0,
    fast_fail_count: 0,
    created_at: '2024-01-01T00:00:00.000Z',
    updated_at: '2024-01-01T00:00:00.000Z',
    started_at: null,
    completed_at: null,
    claimed_by: null,
    failure_reason: null,
    notes: null,
    repo: 'myrepo',
    prompt: null,
    spec: null,
    spec_type: null,
    worktree_path: null,
    needs_review: false,
    next_eligible_at: null,
    playground_enabled: false,
    max_runtime_ms: null,
    max_cost_usd: null,
    duration_ms: null,
    review_diff_snapshot: null,
    rebase_base_sha: null,
    rebased_at: null,
    depends_on: null,
    epic_id: null,
    group_id: null,
    ...overrides
  } as SprintTask
}

function makeRepo(task: SprintTask): { repo: IAgentTaskRepository; updates: Record<string, unknown>[] } {
  const updates: Record<string, unknown>[] = []
  const repo: IAgentTaskRepository = {
    getTask: (id: string) => (id === task.id ? task : null),
    updateTask: (_id: string, patch: Record<string, unknown>) => {
      updates.push(patch)
      return { ...task, ...patch } as SprintTask
    }
  } as unknown as IAgentTaskRepository
  return { repo, updates }
}

const silentLogger = {
  info: vi.fn(),
  warn: vi.fn(),
  error: vi.fn(),
  debug: vi.fn()
}

describe('transitionToReview', () => {
  it('resets fast_fail_count to 0 on success even when previously non-zero', async () => {
    const task = makeMinimalTask({ fast_fail_count: 2, retry_count: 1, started_at: null })
    const { repo, updates } = makeRepo(task)

    await transitionToReview({
      taskId: task.id,
      worktreePath: '/tmp/worktree',
      rebaseNote: undefined,
      rebaseBaseSha: undefined,
      rebaseSucceeded: false,
      repo,
      logger: silentLogger as never
    })

    expect(updates).toHaveLength(1)
    expect(updates[0]).toMatchObject({ fast_fail_count: 0 })
  })

  it('resets retry_count to 0 on success even when previously non-zero', async () => {
    const task = makeMinimalTask({ fast_fail_count: 2, retry_count: 3, started_at: null })
    const { repo, updates } = makeRepo(task)

    await transitionToReview({
      taskId: task.id,
      worktreePath: '/tmp/worktree',
      rebaseNote: undefined,
      rebaseBaseSha: undefined,
      rebaseSucceeded: false,
      repo,
      logger: silentLogger as never
    })

    expect(updates).toHaveLength(1)
    expect(updates[0]).toMatchObject({ retry_count: 0 })
  })

  it('resets both retry_count and fast_fail_count to 0 in a single update', async () => {
    const task = makeMinimalTask({ fast_fail_count: 2, retry_count: 3, started_at: null })
    const { repo, updates } = makeRepo(task)

    await transitionToReview({
      taskId: task.id,
      worktreePath: '/tmp/worktree',
      rebaseNote: undefined,
      rebaseBaseSha: undefined,
      rebaseSucceeded: false,
      repo,
      logger: silentLogger as never
    })

    expect(updates[0]).toMatchObject({ retry_count: 0, fast_fail_count: 0, status: 'review' })
  })
})
